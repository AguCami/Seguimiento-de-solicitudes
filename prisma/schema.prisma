generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SOLICITANTE")
  sector    String?
  avatarUrl String?
  createdAt DateTime @default(now())

  requestsCreated  Request[]             @relation("CreatedBy")
  comments         Comment[]
  history          RequestHistory[]
  messagesSent     DirectMessage[]       @relation("MessagesSent")
  messagesReceived DirectMessage[]       @relation("MessagesReceived")
  sharedRequests   RequestCollaborator[]
}

model Sector {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  requests    Request[]
}

model Request {
  id          String    @id @default(cuid())
  title       String
  description String
  status      String    @default("PENDIENTE")
  priority    String    @default("MEDIA")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  requestedTo  String?

  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  comments      Comment[]
  history       RequestHistory[]
  attachments   Attachment[]
  collaborators RequestCollaborator[]
}

model RequestCollaborator {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  authorId    String
  author      User                @relation(fields: [authorId], references: [id])
  attachments CommentAttachment[]
}

model CommentAttachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model RequestHistory {
  id        String   @id @default(cuid())
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model DirectMessage {
  id         String   @id @default(cuid())
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id])

  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())

  requestId String
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
}
